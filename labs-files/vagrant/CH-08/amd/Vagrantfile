Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/focal64"
  config.vm.hostname = "filesystems-lab"
  config.vm.synced_folder ".", "/vagrant", disabled: true

  config.vm.provider "virtualbox" do |vb|
    vb.memory = 1024
    vb.cpus = 2
  end

  # Keep the OS disk roomy enough for package installs and repeated lab work.
  config.vm.disk :disk, size: "20GB", primary: true

  # Extra blank disks for partitioning, formatting, mounting, and fstab demos.
  config.vm.disk :disk, size: "5GB",  name: "lab-disk-1"
  config.vm.disk :disk, size: "5GB",  name: "lab-disk-2"
  config.vm.disk :disk, size: "10GB", name: "lab-disk-3"
  config.vm.disk :disk, size: "3GB",  name: "lab-disk-4"
  config.vm.disk :disk, size: "4GB",  name: "lab-disk-5"

  config.vm.provision "shell", inline: <<-SHELL
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    apt-get update -y
    apt-get install -y \
      parted \
      gdisk \
      xfsprogs \
      e2fsprogs \
      dosfstools \
      ncdu
  SHELL
end
