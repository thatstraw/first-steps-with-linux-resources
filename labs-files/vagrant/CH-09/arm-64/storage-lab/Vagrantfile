# storage-lab/Vagrantfile
Vagrant.configure("2") do |config|
  config.vm.box = "rockylinux10"
  config.vm.hostname = "storage-lab"
  config.vm.synced_folder ".", "/vagrant", disabled: true

  config.vm.provider "virtualbox" do |vb|
    vb.memory = 1024
    vb.cpus = 2
  end

  # Resize the main OS disk (optional)
  config.vm.disk :disk, size: "20GB", primary: true

  # Add 6 extra lab disks (each 3GB)
  (1..7).each do |i|
    config.vm.disk :disk, size: "3GB", name: "lab-disk-#{i}"
  end

  # Provisioning: detect package manager and install required packages
  config.vm.provision "shell", inline: <<-SHELL
    set -eux

    if command -v apt-get >/dev/null 2>&1; then
      export DEBIAN_FRONTEND=noninteractive
      apt-get update -y
      apt-get install -y lvm2 mdadm quota nfs-common gdisk parted e2fsprogs xfsprogs
    elif command -v dnf >/dev/null 2>&1 || command -v yum >/dev/null 2>&1; then
      if command -v dnf >/dev/null 2>&1; then
        PKG_MGR=dnf
      else
        PKG_MGR=yum
      fi
      $PKG_MGR -y update
      # Enable EPEL for packages like gdisk if available
      $PKG_MGR -y install epel-release || true
      $PKG_MGR -y install lvm2 mdadm quota nfs-utils gdisk parted e2fsprogs xfsprogs || true
    else
      echo "No supported package manager found (apt-get/dnf/yum)." >&2
      exit 1
    fi
  SHELL
end
